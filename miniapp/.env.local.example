# Copy to .env.local and fill in before deploying to Vercel

# Your bot's API server URL (where api_server.py is running)
# e.g. if hosted on a VPS: https://your-vps-domain.com
# Leave empty to use static fallback data
BOT_BACKEND_URL=https://your-server.com

# Your bot's Telegram username
NEXT_PUBLIC_BOT_USERNAME=GammaChkerbot
